# Infisical self-hosted — copy to infisical/.env and fill in.
# These are YOUR instance's secrets: generate them, they come from nowhere else.
#   ENCRYPTION_KEY:  openssl rand -hex 16
#   AUTH_SECRET:     openssl rand -base64 32
#   INFISICAL_DB_PASSWORD: openssl rand -hex 16
ENCRYPTION_KEY=
AUTH_SECRET=
INFISICAL_DB_PASSWORD=

# In-network connection strings (service names from docker-compose.yml).
# Keep the password segment in sync with INFISICAL_DB_PASSWORD.
DB_CONNECTION_URI=postgres://infisical:${INFISICAL_DB_PASSWORD}@db:5432/infisical
REDIS_URL=redis://redis:6379
SITE_URL=http://localhost:8085
TELEMETRY_ENABLED=false
