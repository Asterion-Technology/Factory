{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Observation Deck",
      "type": "shell",
      "command": "bash scripts/serve-dashboard.sh",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Factory Observation Deck",
          "endsPattern": "Accepting connections at"
        }
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "label": "Observation Deck"
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
