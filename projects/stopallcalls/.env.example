# StopAllCalls — local development environment template (DEV-006)
# Copy to .env for local overrides. NEVER commit real values.
# All providers default to deterministic fakes (DEV-003); no real credentials
# are required for local development. Real secrets go in Wrangler secrets only
# (ARC-007), never in this repo.

# fake | sandbox (sandbox requires provider credentials via Wrangler secrets)
PROVIDER_MODE=fake

# Turnstile (INT-008). Both empty => FakeTurnstileAdapter + no widget (the
# default for tests). Set both (apps/web/.env.local) to exercise the real
# widget locally; in deployed envs the secret is a Wrangler secret.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Clio Manage (Phase 3) — OAuth client config, sandbox only
CLIO_CLIENT_ID=
# Clio only accepts HTTPS or http://127.0.0.1 (not localhost) redirect URIs;
# open local dev at 127.0.0.1 when exercising the OAuth flow.
CLIO_REDIRECT_URI=http://127.0.0.1:3000/api/oauth/clio/callback

# Payment provider (Phase 4) — hosted fields; no PAN/CVV ever touches this app
PAYMENT_PROVIDER=fake

# Identity verification provider (Phase 4)
IDENTITY_PROVIDER=fake

# E-signature provider (Phase 4)
SIGNATURE_PROVIDER=fake

# Outbound email (Phase 5) — verified firm sender domain (DLV-002)
EMAIL_FROM=letters@example.test
